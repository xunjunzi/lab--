    }
    .user-badge {
      background: #eef2ff;
      color: #4338ca;
      padding: 8px 16px;
      border-radius: 40px;
      font-size: 0.85rem;
      font-weight: 600;
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .role-switch-btn {
      background: #f59e0b;
      color: white;
      border: none;
      border-radius: 20px;
      padding: 6px 14px;
      font-size: 0.75rem;
      font-weight: 600;
      cursor: pointer;
      transition: 0.2s;
    }
    .role-switch-btn:active {
      background: #d97706;
      transform: scale(0.95);
    }
    .card {
      background: #ffffff;
      border-radius: 22px;
      padding: 18px;
      margin-bottom: 16px;
      box-shadow: 0 6px 20px rgba(0,0,0,0.05);
      border: 1px solid #f1f5f9;
    }
    .input-group {
      margin-bottom: 14px;
    }
    label {
      font-size: 0.85rem;
      font-weight: 600;
      color: #475569;
      display: block;
      margin-bottom: 5px;
      text-transform: uppercase;
      letter-spacing: 0.3px;
    }
    input, select {
      width: 100%;
      padding: 13px 16px;
      border: 2px solid #e2e8f0;
      border-radius: 16px;
      font-size: 0.95rem;
      background: #f8fafc;
      transition: 0.2s;
      outline: none;
    }
    input:focus, select:focus {
      border-color: #6366f1;
      background: white;
      box-shadow: 0 0 0 4px rgba(99,102,241,0.08);
    }
    .time-range-container {
      display: flex;
      gap: 10px;
      align-items: center;
    }
    .time-range-container select {
      flex: 1;
    }
