<body>
<div class="app-container" id="appContainer"></div>

<script>
  (function() {
    // ---------- 存储引擎 ----------
    const STORAGE = {
      USERS: 'lab4_users',
      INSTRUMENTS: 'lab4_instruments',
      RECORDS: 'lab4_records',
      CURRENT: 'lab4_current'
    };

    // 仪器状态枚举
    const STATUS = {
      AVAILABLE: '可使用',
      IN_USE: '使用中',
      MAINTENANCE: '维护中'
    };

    // 生成24小时选项 (0-23小时)
    function generateHourOptions() {
      let options = '';
      for (let h = 0; h < 24; h++) {
        const hourStr = String(h).padStart(2, '0') + ':00';
        options += `<option value="${h}">${hourStr}</option>`;
      }
      return options;
    }

    const HOUR_OPTIONS = generateHourOptions();

    // 默认管理员 + 普通用户
    const DEFAULT_USERS = [
      { id: 'admin_001', username: 'admin', password: 'admin123', role: 'admin', createdAt: new Date().toISOString() },
      { id: 'user_001', username: 'user1', password: 'user123', role: 'user', createdAt: new Date().toISOString() }
    ];

    const DEFAULT_INSTRUMENTS = [
      { id: 'ins_1', name: '高效液相色谱仪', model: 'Agilent 1260', status: STATUS.AVAILABLE },
      { id: 'ins_2', name: '紫外分光光度计', model: 'UV-2600', status: STATUS.AVAILABLE },
      { id: 'ins_3', name: '高速离心机', model: 'Eppendorf 5424', status: STATUS.MAINTENANCE }
    ];

    function initData() {
      if (!localStorage.getItem(STORAGE.USERS)) localStorage.setItem(STORAGE.USERS, JSON.stringify(DEFAULT_USERS));
      if (!localStorage.getItem(STORAGE.INSTRUMENTS)) localStorage.setItem(STORAGE.INSTRUMENTS, JSON.stringify(DEFAULT_INSTRUMENTS));
      if (!localStorage.getItem(STORAGE.RECORDS)) localStorage.setItem(STORAGE.RECORDS, JSON.stringify([]));
    }
    initData();

    const getUsers = () => JSON.parse(localStorage.getItem(STORAGE.USERS)) || [];
    const getInstruments = () => JSON.parse(localStorage.getItem(STORAGE.INSTRUMENTS)) || [];
    const getRecords = () => JSON.parse(localStorage.getItem(STORAGE.RECORDS)) || [];
    const getCurrentUser = () => JSON.parse(localStorage.getItem(STORAGE.CURRENT));

    function saveUsers(u) { localStorage.setItem(STORAGE.USERS, JSON.stringify(u)); }
    function saveInstruments(i) { localStorage.setItem(STORAGE.INSTRUMENTS, JSON.stringify(i)); }
    function saveRecords(r) { localStorage.setItem(STORAGE.RECORDS, JSON.stringify(r)); }
    function setCurrentUser(user) { localStorage.setItem(STORAGE.CURRENT, JSON.stringify(user)); }
    function clearCurrentUser() { localStorage.removeItem(STORAGE.CURRENT); }

    function generateId() { return Date.now().toString(36) + Math.random().toString(36).substr(2, 8); }
    function formatDateTime(iso) {
      const d = new Date(iso);
      return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')} ${String(d.getHours()).padStart(2,'0')}:${String(d.getMinutes()).padStart(2,'0')}`;
    }
    
    function formatHour(hour) {
      return String(hour).padStart(2, '0') + ':00';
    }

    let currentUser = getCurrentUser();
    const app = document.getElementById('appContainer');

    // ---------- 界面渲染 ----------
    function renderLogin() {
      app.innerHTML = `
        <div class="screen">
          <div style="text-align:center; margin-top:35px;">
            <h2 style="font-size:2rem;">🧪 实验室仪器</h2>
            <p class="text-muted">登记管理系统</p>
          </div>
          <div class="card" style="margin-top:30px;">
            <div class="input-group"><label>👤 用户名</label><input id="loginUser" placeholder="输入用户名"></div>
            <div class="input-group"><label>🔒 密码</label><input type="password" id="loginPass" placeholder="输入密码"></div>
            <button class="btn" id="loginBtn">登 录</button>
            <button class="btn btn-outline" id="goRegister">注册新账号</button>
          </div>
          <p class="text-muted" style="text-align:center; margin-top:15px;">默认管理员 admin / admin123</p>
          <p class="text-muted" style="text-align:center;">普通用户 user1 / user123</p>
        </div>
      `;
      document.getElementById('loginBtn').onclick = handleLogin;
      document.getElementById('goRegister').onclick = renderRegister;
    }

    function handleLogin() {
      const u = document.getElementById('loginUser').value.trim();
      const p = document.getElementById('loginPass').value.trim();
      if(!u||!p) return alert('请输入完整信息');
      const user = getUsers().find(x => x.username === u && x.password === p);
      if(!user) return alert('用户名或密码错误');
      currentUser = user;
      setCurrentUser(user);
      renderMain();
    }

    function renderRegister() {
      app.innerHTML = `
        <div class="screen">
          <button class="btn-small btn-outline" id="backLogin" style="margin-bottom:12px;">← 返回登录</button>
          <h2>📝 注册</h2>
          <div class="card">
            <div class="input-group"><label>用户名</label><input id="regUser"></div>
            <div class="input-group"><label>密码 (至少4位)</label><input type="password" id="regPass"></div>
            <button class="btn" id="regSubmit">注册</button>
          </div>
        </div>
      `;
      document.getElementById('backLogin').onclick = renderLogin;
      document.getElementById('regSubmit').onclick = () => {
        const u = document.getElementById('regUser').value.trim();
        const p = document.getElementById('regPass').value.trim();
        if(!u||!p) return alert('填写完整');
        if(p.length<4) return alert('密码至少4位');
        const users = getUsers();
        if(users.find(x=>x.username===u)) return alert('用户名已存在');
        users.push({ id: generateId(), username: u, password: p, role: 'user', createdAt: new Date().toISOString() });
        saveUsers(users);
        alert('注册成功！');
        renderLogin();
      };
    }

    function logout() {
      clearCurrentUser();
      currentUser = null;
      renderLogin();
    }

    function switchRole() {
      if (!currentUser) return;
      const users = getUsers();
      const oppositeRole = currentUser.role === 'admin' ? 'user' : 'admin';
      const switchUser = users.find(u => u.role === oppositeRole);
      if (switchUser) {
        currentUser = switchUser;
        setCurrentUser(switchUser);
        renderMain();
        alert(`已切换为 ${oppositeRole === 'admin' ? '管理员' : '普通用户'} 账号：${switchUser.username}`);
      } else {
        alert(`没有${oppositeRole === 'admin' ? '管理员' : '普通用户'}账号可切换`);
      }
    }

    function renderMain() {
      if (!currentUser) { renderLogin(); return; }
      const instruments = getInstruments();
      const records = getRecords();
      const isAdmin = currentUser.role === 'admin';

      // 普通用户只显示可使用的仪器
      const availableInstruments = instruments.filter(i => i.status === STATUS.AVAILABLE);
      const instrumentOptions = (isAdmin ? instruments : availableInstruments).map(i => 
        `<option value="${i.id}">${i.name} (${i.model||'无型号'}) - ${i.status}</option>`
      ).join('');

      const myRecords = records.filter(r => r.userId === currentUser.id).slice(-5);
      const myRecordsHtml = myRecords.length ? myRecords.map(r => `
        <div class="record-row">
          <span><strong>${r.instrumentName}</strong></span>
          <span>${r.timeSlot}</span>
          <span class="text-muted">${formatDateTime(r.createdAt)}</span>
        </div>
      `).join('') : '<div class="empty-message">暂无使用记录</div>';

      let adminHtml = '';
      if (isAdmin) {
        adminHtml = `
          <div class="admin-panel">
            <h4 style="margin-bottom:12px;">🔧 仪器管理 (增删/修改状态)</h4>
            <div class="flex-row" style="margin-bottom:10px;">
              <input id="newInsName" placeholder="仪器名称" style="flex:2;">
              <input id="newInsModel" placeholder="型号" style="flex:1.5;">
            </div>
            <button class="btn-small btn-success" id="addInsBtn">➕ 添加仪器</button>
            <div id="adminInsList" style="max-height:200px; overflow-y:auto; margin:12px 0;"></div>
            
            <div class="divider"></div>
            <h4 style="margin-bottom:8px;">📊 全部使用者记录</h4>
            <div id="allRecordsContainer" style="max-height:180px; overflow-y:auto; background:white; border-radius:14px; padding:8px;"></div>
            <button class="btn btn-export" id="exportExcelBtn">📥 一键导出Excel (CSV)</button>
          </div>
        `;
      }

      app.innerHTML = `
        <div class="screen">
          <div class="header">
            <h2>📋 仪器登记</h2>
            <div class="user-section">
              <div class="user-badge">
                ${currentUser.role === 'admin' ? '🔑' : '👤'} ${currentUser.username}
              </div>
              <button class="role-switch-btn" id="switchRoleBtn">⇄ 切换角色</button>
              <span class="logout-link" id="logoutBtn">退出</span>
            </div>
          </div>
          
          <div class="card">
            <label>🔬 选择仪器 (仅显示可使用)</label>
            <select id="instrumentSelect">${instrumentOptions}</select>
            
            <label style="margin-top:14px;">⏱️ 使用时间段 (24小时灵活选择)</label>
            <div class="time-range-container">
              <select id="startHourSelect">
                ${HOUR_OPTIONS}
              </select>
              <span class="time-separator">→</span>
              <select id="endHourSelect">
                ${HOUR_OPTIONS}
              </select>
            </div>
            <p class="hint-text">💡 开始时间必须早于结束时间，可精确到小时</p>
            
            <button class="btn" id="registerUseBtn" style="margin-top:16px;">✅ 登记使用 (自动记录时间)</button>
          </div>

          <div class="card">
            <h4 style="margin-bottom:10px;">📌 我的最近登记</h4>
            ${myRecordsHtml}
          </div>

          ${adminHtml}
        </div>
      `;

      document.getElementById('logoutBtn').onclick = logout;
      document.getElementById('switchRoleBtn').onclick = switchRole;
      
      // 默认设置开始时间为8:00，结束时间为17:00
      const startSelect = document.getElementById('startHourSelect');
      const endSelect = document.getElementById('endHourSelect');
      if (startSelect && endSelect) {
        startSelect.value = '8';  // 默认8:00
        endSelect.value = '17';   // 默认17:00
      }
      
      document.getElementById('registerUseBtn').onclick = () => {
        const insId = document.getElementById('instrumentSelect').value;
        const startHour = parseInt(document.getElementById('startHourSelect').value);
        const endHour = parseInt(document.getElementById('endHourSelect').value);
        
        const ins = getInstruments().find(i => i.id === insId);
        if (!ins) return alert('请选择仪器');
        if (ins.status !== STATUS.AVAILABLE) return alert('该仪器当前不可使用');
        
        // 验证时间合理性
        if (startHour >= endHour) {
          return alert('开始时间必须早于结束时间！');
        }
        
        const timeSlot = `${formatHour(startHour)}-${formatHour(endHour)}`;
        
        // 检查时间冲突（同一仪器同一时间段不能重复登记）
        const existingRecords = getRecords().filter(r => 
          r.instrumentId === insId && 
          r.timeSlot === timeSlot &&
          r.userId !== currentUser.id
        );
        
        if (existingRecords.length > 0) {
          if (!confirm(`该仪器在 ${timeSlot} 时段已被其他人登记，是否继续登记？`)) {
            return;
          }
        }
        
        const rec = {
          id: generateId(),
          userId: currentUser.id,
          username: currentUser.username,
          instrumentId: ins.id,
          instrumentName: ins.name,
          timeSlot: timeSlot,
          startHour: startHour,
          endHour: endHour,
          createdAt: new Date().toISOString()
        };
        
        const allRec = getRecords();
        allRec.push(rec);
        saveRecords(allRec);
        alert(`登记成功！\n仪器：${ins.name}\n时间段：${timeSlot}\n登记时间：${formatDateTime(rec.createdAt)}`);
        renderMain();
      };

      if (isAdmin) {
        renderAdminInstrumentList();
        document.getElementById('addInsBtn').onclick = addInstrument;
        renderAllRecords();
        document.getElementById('exportExcelBtn').onclick = exportToExcel;
      }
    }

    function renderAdminInstrumentList() {
      const listEl = document.getElementById('adminInsList');
      if (!listEl) return;
      const instruments = getInstruments();
      listEl.innerHTML = instruments.map(i => {
        let statusClass = '';
        if (i.status === STATUS.AVAILABLE) statusClass = 'status-available';
        else if (i.status === STATUS.IN_USE) statusClass = 'status-inuse';
        else statusClass = 'status-maintenance';
        
        return `
          <div class="instrument-item">
            <div>
              <strong>${i.name}</strong> <span class="text-muted">${i.model||''}</span>
              <span class="status-badge ${statusClass}">${i.status}</span>
            </div>
            <div class="flex-row" style="gap:6px;">
              <button class="btn-small btn-warning" data-action="status" data-id="${i.id}">状态</button>
              <button class="btn-small btn-danger" data-action="delete" data-id="${i.id}">删除</button>
            </div>
          </div>
        `;
      }).join('');

      listEl.querySelectorAll('button').forEach(btn => {
        btn.onclick = (e) => {
          const action = e.target.getAttribute('data-action');
          const id = e.target.getAttribute('data-id');
          if (action === 'delete') deleteInstrument(id);
          else if (action === 'status') changeInstrumentStatus(id);
        };
      });
    }

    function addInstrument() {
      const name = document.getElementById('newInsName').value.trim();
      const model = document.getElementById('newInsModel').value.trim();
      if (!name) return alert('仪器名称必填');
      const instruments = getInstruments();
      instruments.push({
        id: generateId(),
        name,
        model,
        status: STATUS.AVAILABLE
      });
      saveInstruments(instruments);
      renderMain();
    }

    function deleteInstrument(id) {
      if (!confirm('确定删除该仪器吗？')) return;
      saveInstruments(getInstruments().filter(i => i.id !== id));
      renderMain();
    }

    function changeInstrumentStatus(id) {
      const instruments = getInstruments();
      const ins = instruments.find(i => i.id === id);
      if (!ins) return;
      const statuses = [STATUS.AVAILABLE, STATUS.IN_USE, STATUS.MAINTENANCE];
      const currentIndex = statuses.indexOf(ins.status);
      const nextIndex = (currentIndex + 1) % statuses.length;
      const newStatus = statuses[nextIndex];
      if (confirm(`将 ${ins.name} 状态从 [${ins.status}] 改为 [${newStatus}] 吗？`)) {
        ins.status = newStatus;
        saveInstruments(instruments);
        renderMain();
      }
    }

    function renderAllRecords() {
      const container = document.getElementById('allRecordsContainer');
      if (!container) return;
      const records = getRecords().sort((a,b) => new Date(b.createdAt) - new Date(a.createdAt));
      if (records.length === 0) {
        container.innerHTML = '<div class="empty-message">暂无登记记录</div>';
        return;
      }
      container.innerHTML = records.map(r => `
        <div style="display:flex; justify-content:space-between; font-size:0.8rem; padding:6px; border-bottom:1px solid #eee; flex-wrap:wrap;">
          <span><b>${r.username}</b></span>
          <span>${r.instrumentName}</span>
          <span>${r.timeSlot}</span>
          <span class="text-muted">${formatDateTime(r.createdAt)}</span>
        </div>
      `).join('');
    }

    function exportToExcel() {
      const records = getRecords().sort((a,b) => new Date(b.createdAt) - new Date(a.createdAt));
      if (records.length === 0) {
        alert('没有记录可导出');
        return;
      }
      // 生成CSV (Excel可直接打开)
      let csv = '\uFEFF用户名,仪器名称,使用时间段,登记时间\n';
      records.forEach(r => {
        csv += `"${r.username}","${r.instrumentName}","${r.timeSlot}","${formatDateTime(r.createdAt)}"\n`;
      });
      const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `仪器使用记录_${new Date().toISOString().slice(0,10)}.csv`;
      a.click();
      URL.revokeObjectURL(url);
      alert('导出成功！');
    }

    // 启动
    if (currentUser) renderMain();
    else renderLogin();
  })();
</script>
</body>
</html>
