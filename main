      border: none;
    }
    .btn-success {
      background: #10b981;
      color: white;
      border: none;
    }
    .btn-warning {
      background: #f59e0b;
      color: white;
      border: none;
    }
    .btn-export {
      background: #1e293b;
      color: white;
      border: none;
      margin-top: 12px;
    }
    .flex-row {
      display: flex;
      gap: 10px;
